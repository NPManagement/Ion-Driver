[gd_scene load_steps=10 format=3 uid="uid://ionrace001"]

[ext_resource type="Script"      path="res://scripts/race/race_scene.gd"      id="0_rs"]
[ext_resource type="Script"      path="res://scripts/race/race_manager.gd"    id="1_rm"]
[ext_resource type="Script"      path="res://scripts/track/track_generator.gd" id="2_tg"]
[ext_resource type="Script"      path="res://scripts/race/waypoint_system.gd"  id="3_wp"]
[ext_resource type="Script"      path="res://scripts/ui/hud.gd"                id="4_hud"]
[ext_resource type="Environment" path="res://resources/default_environment.tres" id="5_env"]

# WorldEnvironment, Sky, and lights removed — race_scene.gd creates them programmatically

[node name="Race" type="Node3D"]
script = ExtResource("0_rs")

[node name="TrackGenerator" type="Node3D" parent="."]
script = ExtResource("2_tg")

[node name="WaypointSystem" type="Node" parent="."]
script = ExtResource("3_wp")

[node name="RaceManager" type="Node" parent="."]
script = ExtResource("1_rm")

[node name="HUD" type="CanvasLayer" parent="."]
script = ExtResource("4_hud")
layer = 10
